set relativenumber
set number
set hidden
set hlsearch
set incsearch

" Easier split navigation
nnoremap <C-J> <C-W><C-J>
nnoremap <C-K> <C-W><C-K>
nnoremap <C-H> <C-W><C-H>
nnoremap <C-L> <C-W><C-L>

" Easier buffer navigation
nnoremap <S-J> :tabprev<CR>
nnoremap <S-K> :tabnext<CR>
nnoremap x :q<CR>

nnoremap <leader>a :action Annotate<CR>
nnoremap <leader>h :action QuickJavaDoc<CR>
nnoremap <leader>ca :action ShowIntentionActions<CR>
nnoremap <leader>k :action CheckinProject<CR>
nnoremap <leader><S-K> :action Vcs.Push<CR>

" LSP-equivalent navigation (mirrors NeoVim autocmds.lua bindings)
" <C-]> and <C-S-]> are IntelliJ native defaults — no mapping needed
nnoremap grn :action RenameElement<CR>
nnoremap gd :action GotoDeclaration<CR>
nnoremap gD :action GotoDeclaration<CR>
nnoremap gi :action GotoImplementation<CR>
nnoremap gt :action GotoTypeDeclaration<CR>
nnoremap [d :action GotoPreviousError<CR>
nnoremap ]d :action GotoNextError<CR>
nnoremap <leader>d :action ShowErrorDescription<CR>

nnoremap ,r :action IdeaVim.ReloadVimRc.reload<CR>

" Keep the selection after changing indentation
vnoremap > >gv
vnoremap < <gv

" Clear search by pressing ,/
nmap <silent> ,/ :nohlsearch<CR>

nohlsearch
